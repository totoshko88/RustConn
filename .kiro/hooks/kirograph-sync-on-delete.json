{
  "version": "v1",
  "hooks": [
    {
      "name": "KiroGraph Sync on Delete",
      "description": "Remove deleted files from the KiroGraph index immediately.",
      "trigger": "PostFileDelete",
      "matcher": "\\.(rs|toml)$",
      "action": {
        "type": "command",
        "command": "kirograph sync-if-dirty 2>/dev/null || true"
      },
      "enabled": true
    }
  ]
}
