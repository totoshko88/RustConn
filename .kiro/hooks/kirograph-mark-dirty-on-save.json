{
  "name": "KiroGraph Mark Dirty on Save",
  "version": "1.0.0",
  "description": "Mark the KiroGraph index as dirty when source files are saved. Sync is deferred to agent idle.",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.py",
      "**/*.go",
      "**/*.rs",
      "**/*.java",
      "**/*.cs",
      "**/*.rb",
      "**/*.php",
      "**/*.swift",
      "**/*.kt",
      "**/*.dart"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "kirograph mark-dirty 2>/dev/null || true"
  }
}
